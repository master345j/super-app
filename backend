import os
from fastapi import FastAPI, BackgroundTasks
from fastapi.middleware.cors import CORSMiddleware
from motor.motor_asyncio import AsyncIOMotorClient
from datetime import datetime
import httpx
from bs4 import BeautifulSoup

app = FastAPI()

# 1. ALLOW THE FRONTEND TO TALK TO THE BACKEND
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"], 
    allow_methods=["*"],
    allow_headers=["*"],
)

# 2. MONGODB ATLAS CONNECTION
# When deploying to Render, we will set this in the "Environment" tab
MONGO_URL = os.getenv("MONGO_URL", "mongodb://localhost:27017")
client = AsyncIOMotorClient(MONGO_URL)
db = client.super_aggregator_db
collection = db.services

# 3. THE "SCRAPER" LOGIC
async def scrape_and_save(app_name: str, url: str):
    headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}
    async with httpx.AsyncClient(headers=headers, follow_redirects=True) as client:
        try:
            response = await client.get(url)
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Generic price finder (updates based on Amazon/Flipkart/etc)
            price_box = soup.find("span", {"class": "a-price-whole"}) or soup.find("div", {"class": "_30jeq3"})
            price = price_box.text.strip() if price_box else "N/A"

            data = {
                "app_name": app_name,
                "url": url,
                "current_price": price,
                "last_updated": datetime.utcnow()
            }
            # Update the cloud database
            await collection.update_one({"app_name": app_name}, {"$set": data}, upsert=True)
        except Exception as e:
            print(f"Error: {e}")

# 4. API ENDPOINTS
@app.get("/add-app")
async def add_app(name: str, url: str, background_tasks: BackgroundTasks):
    background_tasks.add_task(scrape_and_save, name, url)
    return {"message": f"Fetching data for {name} in background..."}

@app.get("/get-all")
async def get_all():
    cursor = collection.find({})
    results = await cursor.to_list(length=100)
    for res in results:
        res["_id"] = str(res["_id"]) # Convert ID for JSON compatibility
    return results
